{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('participants').child(auth.uid).exists())",
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "messages": {
          "$msgId": {
            ".write": "auth != null && root.child('sessions').child($sessionId).child('participants').child(auth.uid).exists()"
          }
        }
      }
    }
  }
}
